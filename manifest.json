{
  "manifest_version": 3,
  "name": "Gemini Disable AutoScroll",
  "version": "1.1.0",
  "description": "Disable auto-scroll on Google Gemini",
  "permissions": ["storage"],
  "host_permissions": ["https://gemini.google.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://gemini.google.com/*"]
    }
  ]
}
